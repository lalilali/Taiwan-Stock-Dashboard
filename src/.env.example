# Copy this file to .env and fill in your real credentials
# NEVER commit .env to git

# Fubon account credentials
FUBON_ID=your_login_id
FUBON_PASSWORD=your_password
FUBON_CERT_PATH=C:/path/to/your/certificate.pfx
FUBON_CERT_PASSWORD=your_cert_password

# Set to "false" to go live (real orders will be placed!)
PAPER_TRADING=true
